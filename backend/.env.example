# === EXISTING - OAuth (keep these) ===
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback
GITHUB_OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_API_BASE=https://api.github.com

# === NEW - Infrastructure ===
# PostgreSQL
POSTGRES_USER=conductor
POSTGRES_PASSWORD=conductor_dev
POSTGRES_DB=conductor
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=conductor-memory

# Ollama
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# LLM providers
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Model overrides
TL_REVIEW_MODEL=ollama/qwen2.5-coder:1.5b
DEV_RETRY_MODEL=ollama/qwen2.5-coder:1.5b

# GitHub PAT (used by agents to read/write repos - different from OAuth)
GITHUB_TOKEN=your_github_personal_access_token_here
