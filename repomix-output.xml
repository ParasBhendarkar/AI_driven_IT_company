    task_id = f"test-{uuid4()}"

    state = TaskState(
        task_id=task_id,
        title="Test Task",
        description="Test description",
        repo="owner/repo",
        branch="main",
        priority=Priority.MEDIUM,
        acceptance_criteria=["Test criteria"],
