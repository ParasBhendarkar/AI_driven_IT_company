from memory.short_term import get_task_token
from models.schemas import DevOutput, FileChange, TaskState
from tools.github_tool import GitHubTool

logger = logging.getLogger(__name__)


class DeveloperAgent(BaseAgent):
    role = "Developer"
    model = "ollama/qwen2.5-coder:3b"

    SYSTEM_PROMPT = """
You are an expert software developer agent inside an autonomous AI company system.

You receive a task description, acceptance criteria, the base branch, the working
branch, and the current contents of relevant repository files.

Return ONLY valid JSON in this exact shape:
{
  "commit_message": "short git commit message",
  "pr_title": "pull request title",
  "pr_body": "pull request description",
  "files": [
    {
      "path": "relative/file.py",
      "summary": "one sentence summary of the change",
      "content_b64": "full updated file content encoded in base64"
    }
  ]
}

Rules:
- Modify only files relevant to the task.
- Return full file contents for every changed file encoded as base64 in content_b64.
- KEEP IMPORTS INTACT: If you use a new library (like math or json), you MUST include the import statement at the top of the file.
- Keep changes minimal and correct.
- Do not wrap the JSON in markdown fences.
"""

    async def run(self, state: TaskState) -> TaskState:
        logger.info("NODE ENTERED: developer")
        start = time.time()

        try:
            await self._publish(state.task_id, "Reading repository and planning changes...")

            access_token = await get_task_token(state.task_id) or settings.GITHUB_TOKEN
            if not access_token:
                raise RuntimeError("Missing GitHub token for Developer agent")

            work_branch = state.branch

            gh = GitHubTool(
                repo=state.repo,
                branch=work_branch,
                access_token=access_token,
            )
            await gh.ensure_branch_exists()
            base_branch = await asyncio.to_thread(lambda: gh.repo.default_branch)

            file_context = await self._read_file_context(gh, state)
            messages = [{"role": "user", "content": self._build_prompt(state, base_branch, work_branch, file_context)}]

            response = await self._call_llm(
                messages=messages,
                system=self.SYSTEM_PROMPT,
                temperature=0.1,
                max_tokens=4096,
                timeout_seconds=240,
                json_mode=True,
            )

            # _call_llm returns None on timeout or any exception
            if response is None:
                logger.warning("Developer _call_llm returned None, using fallback dev_output")
                state.dev_output = DevOutput(
                    summary="LLM call failed — no code changes produced",
                    branch=state.branch,
                )
                return state

            tokens_total = response.usage.total_tokens if response.usage else 0
            try:
                plan = await self._parse_plan_with_repair(
                    raw=response.choices[0].message.content or "",
                    messages=messages,
                    state=state,
                )
            except Exception as exc:
                await self._publish(
                    state.task_id,
                    "Structured developer output failed; using deterministic fallback implementation.",
                    event_type="warning",
                    payload={"error": str(exc)},
                )
                plan = await self._build_deterministic_fallback_plan(state, gh, file_context)

            file_changes: list[FileChange] = []
            commit_sha: str | None = None

            context_map = {path: content for path, content in file_context}

            for change in plan["files"]:
                content = self._decode_content(change)
                if context_map.get(change["path"]) == content:
                    await self._publish(
                        state.task_id,
                        f"Skipped {change['path']} (no content change detected)",
                        event_type="warning",
                        payload={"path": change["path"]},
                    )
                    continue
                result = await gh.create_or_update_file(
                    change["path"],
                    content,
                    plan["commit_message"],
                )
                commit_sha = result.get("commit_sha")
                file_changes.append(
                    FileChange(
                        file_path=change["path"],
                        change_type="modify",
                        summary=change["summary"],
                        patch=None,
                    )
                )
                await self._publish(
                    state.task_id,
                    f"Wrote {change['path']} - {change['summary']}",
                    payload={"path": change["path"], "commit_sha": commit_sha},
                )

            pr_number: int | None = None
            pr_result: dict | None = None
            if work_branch != base_branch:
                pr_result = await gh.open_pull_request(
                    title=plan["pr_title"],
                    body=plan["pr_body"],
                    base=base_branch,
                )
                pr_number = pr_result.get("number")
                summary = f"PR #{pr_number} opened with {len(file_changes)} file(s) changed"
            else:
                summary = (
                    f"Committed {len(file_changes)} file(s) directly to branch "
                    f"'{work_branch}' (no PR opened)"
                )

            state.dev_output = DevOutput(
                summary=summary,
                branch=work_branch,
                commit_hash=commit_sha,
                pr_number=pr_number,
                files_changed=file_changes,
            )
            state.pr_number = pr_number
            state.commit_hash = commit_sha

            latency = time.time() - start

            await self._log_call(
                task_id=state.task_id,
                action="developer_run",
                input_payload={"prompt_length": len(messages[0]["content"])},
                output_payload={"pr_number": pr_number, "files_changed": len(file_changes)},
                tokens_used=tokens_total,
                latency_seconds=latency,
            )

            if pr_number is not None and pr_result is not None:
                await self._publish(
                    state.task_id,
                    f"PR #{pr_number} opened: {plan['pr_title']}",
                    event_type="success",
                    payload={"pr_number": pr_number, "pr_url": pr_result.get("url")},
                )
            await self._publish(
                state.task_id,
                summary,
                event_type="success",
            )

            return state

        except Exception as exc:
            logger.error(f"Developer run() crashed: {exc}")
            state.dev_output = DevOutput(
                summary=f"Agent error: {str(exc)}",
                branch=state.branch,
            )
            return state

    async def _read_file_context(self, gh: GitHubTool, state: TaskState) -> list[tuple[str, str]]:
        context: list[tuple[str, str]] = []
        for path in self._extract_paths(state):
            content = await gh.read_file(path)
            if content is not None:
                context.append((path, content))
                await self._publish(state.task_id, f"Read file: {path}")
        return context

    def _build_prompt(
        self,
        state: TaskState,
        base_branch: str,
        work_branch: str,
        file_context: list[tuple[str, str]],
    ) -> str:
        lines = [
            f"Task: {state.title}",
            f"Description: {state.description}",
            f"Repository: {state.repo}",
            f"Base branch: {base_branch}",
            f"Working branch: {work_branch}",
            "",
            "Acceptance criteria:",
        ]
        for criterion in state.acceptance_criteria or []:
            lines.append(f"  - {criterion}")

        if state.qa_result and state.retry_count > 0:
            lines.append("")
            lines.append(build_retry_context(state.qa_result, state.memory_hits or []))

        if state.critic_output:
            root_cause = getattr(
                state.critic_output,
                "root_cause",
                getattr(state.critic_output, "summary", ""),
            )
            fix = getattr(
                state.critic_output,
                "fix",
                getattr(state.critic_output, "recommendation", ""),
            )
            lines.append("")
            lines.append("--- CRITIC ROOT CAUSE ANALYSIS ---")
            lines.append(f"Root cause: {root_cause}")
            lines.append(f"Suggested fix: {fix}")

        if state.memory_hits and state.retry_count == 0:
            lines.append("")
            lines.append("--- RELEVANT PAST KNOWLEDGE ---")
            for hit in state.memory_hits:
                lines.append(f"[{hit.get('score', 0):.0%}] {hit.get('content', '')}")

        if state.tl_review_feedback:
            lines.append("")
            lines.append("--- TEAM LEADER CODE REVIEW FEEDBACK ---")
            lines.append("The Team Leader rejected your previous submission.")
            lines.append(f"Specific issues to fix: {state.tl_review_feedback}")
            lines.append("Fix ONLY these issues. Do not change anything else.")

        if state.tl_final_feedback:
            lines.append("")
            lines.append("--- TEAM LEADER FINAL REVIEW FEEDBACK ---")
            lines.append("Final review rejected. Address these gaps:")
            lines.append(state.tl_final_feedback)

        if state.human_override:
            lines.append("")
            lines.append("HUMAN OVERRIDE INSTRUCTION (HIGHEST PRIORITY)")
            lines.append(state.human_override)
            lines.append("Follow this instruction exactly. It supersedes everything above.")

        lines.append("")
        lines.append("Repository files:")
        for path, content in file_context:
            lines.append("")
            lines.append(f"FILE: {path}")
            lines.append(content)

        return "\n".join(lines)

    def _extract_paths(self, state: TaskState) -> list[str]:
        paths = []
        if state.team_leader_output and state.team_leader_output.file_targets:
            paths.extend(state.team_leader_output.file_targets)
        
        text = "\n".join([state.title, state.description, *state.acceptance_criteria, *state.context_refs])
        matches = re.findall(r"\b[\w./-]+\.[A-Za-z0-9]+\b", text)
        paths.extend(matches)
        
        ordered = list(dict.fromkeys(paths))
        return ordered or ["README.md"]

    def _parse_plan(self, raw: str) -> dict:
        clean = self._extract_json_object(raw.strip())
        data = json.loads(self._escape_json_controls(clean))
        return {
            "commit_message": data["commit_message"],
            "pr_title": data["pr_title"],
            "pr_body": data["pr_body"],
            "files": data["files"],
        }

    async def _parse_plan_with_repair(
        self,
        raw: str,
        messages: list[dict],
        state: TaskState,
    ) -> dict:
        try:
            return self._parse_plan(raw)
        except Exception as first_error:
            await self._publish(
                state.task_id,
                "Model output was malformed JSON, attempting auto-repair...",
                event_type="warning",
                payload={"error": str(first_error)},
            )

            repair_system = """
You are a JSON repair assistant.
Convert the provided malformed model output into strict valid JSON with no markdown fences.
Keep the exact semantic intent.
Use this exact schema:
{
  "commit_message": "string",
  "pr_title": "string",
  "pr_body": "string",
  "files": [
    {
      "path": "relative/file.py",
      "summary": "string",
      "content_b64": "full updated file content encoded in base64"
    }
  ]
}
Only output JSON.
"""
            repair_messages = [
                {
                    "role": "user",
                    "content": (
                        "Original task prompt:\n"
                        f"{messages[0]['content']}\n\n"
                        "Malformed output to repair:\n"
                        f"{raw}"
                    ),
                }
            ]
            repair_response = await self._call_llm(
                messages=repair_messages,
                system=repair_system,
                temperature=0.0,
                max_tokens=4096,
                timeout_seconds=240,
                json_mode=True,
            )
            if repair_response is None:
                raise RuntimeError("Repair LLM call returned None")
            repaired_raw = repair_response.choices[0].message.content or ""
            try:
                return self._parse_plan(repaired_raw)
            except Exception:
                retry_system = """
You are a software developer agent that MUST return strict JSON only.
Return exactly this schema and nothing else:
{
  "commit_message": "string",
  "pr_title": "string",
  "pr_body": "string",
  "files": [
    {
      "path": "relative/path.py",
      "summary": "string",
      "content_b64": "full updated file content encoded in base64"
    }
  ]
}
"""
                retry_response = await self._call_llm(
                    messages=messages,
                    system=retry_system,
                    temperature=0.0,
                    max_tokens=4096,
                    timeout_seconds=240,
                    json_mode=True,
                )
                if retry_response is None:
                    raise RuntimeError("Retry LLM call returned None")
                retry_raw = retry_response.choices[0].message.content or ""
                return self._parse_plan(retry_raw)

    async def _build_deterministic_fallback_plan(
        self,
        state: TaskState,
        gh: GitHubTool,
        file_context: list[tuple[str, str]],
    ) -> dict:
        task_text = " ".join([state.title, state.description, *state.acceptance_criteria]).lower()
        scientific_keywords = ("sine", "cosine", "tangent", "logarithm")
        if not all(word in task_text for word in scientific_keywords):
            raise RuntimeError("Fallback implementation unavailable for this task type")

        context_map = {path: content for path, content in file_context}

        calc_path = "calculator.py"
        calc_original = context_map.get(calc_path)
        if calc_original is None:
            calc_original = await gh.read_file(calc_path) or ""
        calc_updated = self._ensure_scientific_calculator_functions(calc_original)

        test_path = "test_calculator.py"
        test_original = context_map.get(test_path)
        if test_original is None:
            test_original = await gh.read_file(test_path) or ""
        test_updated = self._ensure_scientific_tests(test_original)

        files: list[dict] = []
        if calc_updated != calc_original:
            files.append(
                {
                    "path": calc_path,
                    "summary": "Add sine, cosine, tangent, and logarithm calculator functions",
                    "content": calc_updated,
                }
            )
        if test_updated != test_original:
            files.append(
                {
                    "path": test_path,
                    "summary": "Add unit tests for scientific calculator functions",
                    "content": test_updated,
                }
            )

        if not files:
            raise RuntimeError("Fallback implementation produced no file changes")

        return {
            "commit_message": "feat: add advanced scientific calculator operations",
            "pr_title": "Implement advanced scientific operations",
            "pr_body": "Adds sine, cosine, tangent, and logarithm functions with corresponding unit tests.",
            "files": files,
        }

    def _ensure_scientific_calculator_functions(self, content: str) -> str:
        text = content or ""
        if "import math" not in text:
            text = ("import math\n\n" + text.lstrip()) if text.strip() else "import math\n"

        additions: list[str] = []

        if not re.search(r"(?m)^def\s+sine\s*\(", text):
            additions.append(
                """
def sine(x: float) -> float:
    return math.sin(x)
""".strip()
            )
        if not re.search(r"(?m)^def\s+cosine\s*\(", text):
            additions.append(
                """
def cosine(x: float) -> float:
    return math.cos(x)
""".strip()
            )
        if not re.search(r"(?m)^def\s+tangent\s*\(", text):
            additions.append(
                """
def tangent(x: float) -> float:
    cosine_value = math.cos(x)
    if math.isclose(cosine_value, 0.0, abs_tol=1e-12):
        raise ValueError("tangent undefined for this input")
    return math.tan(x)
""".strip()
            )
        if not re.search(r"(?m)^def\s+logarithm\s*\(", text):
            additions.append(
                """
def logarithm(x: float, base: float = math.e) -> float:
    if x <= 0:
        raise ValueError("logarithm undefined for non-positive values")
    if base <= 0 or math.isclose(base, 1.0, abs_tol=1e-12):
        raise ValueError("logarithm base must be > 0 and not equal to 1")
    return math.log(x, base)
""".strip()
            )

        if not additions:
            return text

        suffix = "\n\n" + "\n\n".join(additions) + "\n"
        if text.endswith("\n"):
            return text + suffix.lstrip("\n")
        return text + suffix

    def _ensure_scientific_tests(self, content: str) -> str:
        text = content or ""
        if not text.strip():
            return """import math
import pytest

from calculator import cosine, logarithm, sine, tangent


def test_sine_values():
    assert sine(0.0) == pytest.approx(0.0)
    assert sine(math.pi / 2) == pytest.approx(1.0)


def test_cosine_values():
    assert cosine(0.0) == pytest.approx(1.0)
    assert cosine(math.pi) == pytest.approx(-1.0)


def test_tangent_values():
    assert tangent(0.0) == pytest.approx(0.0)


def test_tangent_undefined():
    with pytest.raises(ValueError):
        tangent(math.pi / 2)


def test_logarithm_values():
    assert logarithm(100.0, 10.0) == pytest.approx(2.0)
    assert logarithm(math.e) == pytest.approx(1.0)


def test_logarithm_invalid_inputs():
    with pytest.raises(ValueError):
        logarithm(0.0)
    with pytest.raises(ValueError):
        logarithm(-1.0)
    with pytest.raises(ValueError):
        logarithm(10.0, 1.0)
"""

        updated = text
        if "import math" not in updated:
            updated = "import math\n" + updated
        if "import pytest" not in updated:
            updated = "import pytest\n" + updated
        if "from calculator import" not in updated:
            updated = "from calculator import cosine, logarithm, sine, tangent\n" + updated

        blocks: list[str] = []
        if "def test_sine_values(" not in updated:
            blocks.append(
                """
def test_sine_values():
    assert sine(0.0) == pytest.approx(0.0)
    assert sine(math.pi / 2) == pytest.approx(1.0)
""".strip()
            )
        if "def test_cosine_values(" not in updated:
            blocks.append(
                """
def test_cosine_values():
    assert cosine(0.0) == pytest.approx(1.0)
    assert cosine(math.pi) == pytest.approx(-1.0)
""".strip()
            )
        if "def test_tangent_values(" not in updated:
            blocks.append(
                """
def test_tangent_values():
    assert tangent(0.0) == pytest.approx(0.0)
""".strip()
            )
        if "def test_tangent_undefined(" not in updated:
            blocks.append(
                """
def test_tangent_undefined():
    with pytest.raises(ValueError):
        tangent(math.pi / 2)
""".strip()
            )
        if "def test_logarithm_values(" not in updated:
            blocks.append(
                """
def test_logarithm_values():
    assert logarithm(100.0, 10.0) == pytest.approx(2.0)
    assert logarithm(math.e) == pytest.approx(1.0)
""".strip()
            )
        if "def test_logarithm_invalid_inputs(" not in updated:
            blocks.append(
                """
def test_logarithm_invalid_inputs():
    with pytest.raises(ValueError):
        logarithm(0.0)
    with pytest.raises(ValueError):
        logarithm(-1.0)
    with pytest.raises(ValueError):
        logarithm(10.0, 1.0)
""".strip()
            )

        if not blocks:
            return updated

        sep = "\n\n" if updated.endswith("\n") else "\n\n"
        return updated + sep + "\n\n".join(blocks) + "\n"

    def _work_branch_name(self, state: TaskState) -> str:
        slug = re.sub(r"[^\w\s-]", "", state.title.lower())
        slug = re.sub(r"[\s_-]+", "-", slug).strip("-")[:50]
        return f"feat/{slug}"

    def _extract_json_object(self, raw: str) -> str:
        cleaned = raw
        if cleaned.startswith("```"):
            cleaned = cleaned.split("```", 2)[1].replace("json", "", 1).strip()

        start = cleaned.find("{")
        end = cleaned.rfind("}")
        if start == -1 or end == -1 or end < start:
            raise ValueError("Developer model did not return a JSON object")
        return cleaned[start : end + 1]

    def _escape_json_controls(self, raw: str) -> str:
        escaped: list[str] = []
        in_string = False
        escaping = False

        for char in raw:
            if in_string:
                if escaping:
                    escaped.append(char)
                    escaping = False
                    continue
                if char == "\\":
                    escaped.append(char)
                    escaping = True
                    continue
                if char == '"':
                    escaped.append(char)
                    in_string = False
                    continue
                if char == "\n":
                    escaped.append("\\n")
                    continue
                if char == "\r":
                    escaped.append("\\r")
                    continue
                if char == "\t":
                    escaped.append("\\t")
                    continue
                escaped.append(char)
                continue

            escaped.append(char)
            if char == '"':
                in_string = True

        return "".join(escaped)

    def _decode_content(self, file_item: dict) -> str:
        content_b64 = file_item.get("content_b64")
        if isinstance(content_b64, str) and content_b64:
            try:
                return base64.b64decode(content_b64).decode("utf-8")
            except Exception:
                logger.warning("Invalid content_b64 payload for path %s", file_item.get("path"))
        return str(file_item.get("content", ""))
